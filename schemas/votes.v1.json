{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "votes.v1.json",
  "title": "Per-pick votes snapshot v1",
  "type": "object",
  "required": ["schema_version", "pick_id", "likes", "dislikes", "generated_at"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\." },
    "pick_id": { "type": "integer", "minimum": 1 },
    "likes": { "type": "integer", "minimum": 0 },
    "dislikes": { "type": "integer", "minimum": 0 },
    "generated_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
