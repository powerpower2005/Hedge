{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "instrument_bars.v1.json",
  "title": "Instrument daily bars v1",
  "type": "object",
  "required": [
    "schema_version",
    "generator",
    "generated_at",
    "instrument",
    "source",
    "updated_at",
    "bars"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\." },
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "commit": { "type": "string" }
      }
    },
    "generated_at": { "type": "string", "minLength": 1 },
    "instrument": {
      "type": "object",
      "required": ["country", "market", "ticker"],
      "properties": {
        "country": { "enum": ["US", "KR", "HK", "JP"] },
        "market": {
          "enum": [
            "NASDAQ",
            "NYSE",
            "NYSEARCA",
            "BATS",
            "NYSEAMERICAN",
            "KRX",
            "KOSPI",
            "KOSDAQ",
            "HKG",
            "TYO"
          ]
        },
        "ticker": { "type": "string", "pattern": "^[A-Z0-9]{1,10}$" }
      }
    },
    "source": { "enum": ["google_sheets_googfinance"] },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Latest bar date included in this file."
    },
    "bars": {
      "type": "array",
      "items": { "$ref": "#/definitions/bar" }
    }
  },
  "definitions": {
    "bar": {
      "type": "object",
      "required": ["date", "open", "high", "low", "close"],
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "open": { "type": "number", "exclusiveMinimum": 0 },
        "high": { "type": "number", "exclusiveMinimum": 0 },
        "low": { "type": "number", "exclusiveMinimum": 0 },
        "close": { "type": "number", "exclusiveMinimum": 0 },
        "volume": { "type": ["number", "null"], "minimum": 0 }
      }
    }
  }
}
