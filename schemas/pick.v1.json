{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pick.v1.json",
  "title": "Pick Record v1",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "created_with",
    "created_at",
    "author",
    "issue_number",
    "ticker",
    "country",
    "market",
    "entry",
    "target",
    "duration",
    "status"
  ],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "schema_version": { "type": "string", "pattern": "^1\\." },
    "created_with": {
      "type": "object",
      "required": ["engine_version", "rules_version"],
      "properties": {
        "engine_version": { "type": "string" },
        "rules_version": { "type": "string" },
        "commit": { "type": "string" }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "issue_number": { "type": "integer", "minimum": 1 },
    "ticker": { "type": "string", "pattern": "^[A-Z0-9]{1,10}$" },
    "country": { "enum": ["US", "KR"] },
    "market": {
      "enum": ["NASDAQ", "NYSE", "NYSEARCA", "BATS", "NYSEAMERICAN", "KRX", "KOSPI", "KOSDAQ"],
      "description": "US: GOOGLEFINANCE exchange prefix. KR: board label (KRX/KOSPI/KOSDAQ); Sheets use KRX: for all Korean rows via mapping."
    },
    "instrument_name": {
      "type": "string",
      "maxLength": 280,
      "description": "Optional display name from GOOGLEFINANCE(..., \"name\") at registration (Sheets)."
    },
    "author_note": {
      "type": "string",
      "maxLength": 2000,
      "description": "Optional free text from the registration issue form (e.g. context); shown on the public pick detail when present."
    },
    "entry": {
      "type": "object",
      "required": ["date", "source"],
      "properties": {
        "price": { "type": "number", "exclusiveMinimum": 0 },
        "pending": {
          "type": "boolean",
          "description": "True until first daily judgment locks entry.price (rules >= 1.0.7)."
        },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "source": { "type": "string" },
        "close_session_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Trading session calendar date for entry.price (GOOGLEFINANCE closeyest); at registration, Sheets column F walks backward up to 14 calendar days for the first numeric daily close."
        }
      }
    },
    "target": {
      "type": "object",
      "required": ["return_rate"],
      "properties": {
        "return_rate": {
          "type": "number",
          "minimum": -10.0,
          "maximum": 10.0,
          "description": "Fractional return vs entry; |return_rate| >= 0.10 enforced at registration. Negative = bearish (target price below entry)."
        },
        "price": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "duration": {
      "type": "object",
      "required": ["days"],
      "properties": {
        "days": { "type": "integer", "enum": [7, 14, 30, 90, 180] },
        "deadline": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Set when entry locks (pending_entry picks omit until first judgment)."
        }
      }
    },
    "status": {
      "type": "object",
      "required": ["current", "history"],
      "properties": {
        "current": {
          "enum": ["pending_entry", "active", "achieved", "expired", "suspended", "delisted"]
        },
        "history": { "type": "array" }
      }
    },
    "progress": { "type": "object" },
    "votes": { "type": "object" },
    "achievement": { "type": "object" },
    "extensions": { "type": "object" },
    "expiry": {
      "type": "object",
      "description": "Last in-window judgment close, snapshotted when the pick expires (before post-deadline progress overwrite).",
      "properties": {
        "close": { "type": "number", "exclusiveMinimum": 0 },
        "session_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "return_rate": { "type": "number" }
      }
    },
    "expired_at": { "type": "string", "minLength": 1 },
    "suspended_at": { "type": "string", "minLength": 1 },
    "delisted_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
